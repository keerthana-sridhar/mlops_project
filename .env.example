AIRFLOW_UID=50000
FERNET_KEY=replace-with-a-generated-fernet-key
MLFLOW_TRACKING_URI=http://mlflow:5000

# Optional alert email settings for Alertmanager.
# Leave these blank to keep webhook-only alerts.
SMTP_SMARTHOST=smtp.example.com:587
ALERT_EMAIL_FROM=alerts@example.com
ALERT_EMAIL_TO=you@example.com
SMTP_AUTH_USERNAME=alerts@example.com
SMTP_AUTH_PASSWORD=replace-with-app-password
SMTP_REQUIRE_TLS=true

# Optional monitoring thresholds.
CONF_THRESHOLD=0.6
DRIFT_THRESHOLD=0.5
OOD_RATE_THRESHOLD=0.2
INPUT_MEAN_DRIFT_THRESHOLD=0.2
